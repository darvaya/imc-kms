# ─────────────────────────────────────────────────────────────────────────────
# IMC Pelita Logistik KMS - Environment Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED - Core Settings
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development

# The fully qualified URL where the app is hosted
URL=http://localhost:3000
PORT=3000

# Generate both with: openssl rand -hex 32
SECRET_KEY=
UTILS_SECRET=

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED - Database (PostgreSQL)
# ══════════════════════════════════════════════════════════════════════════════

# Either use DATABASE_URL or individual components (not both)
DATABASE_URL=postgres://user:password@localhost:5432/outline

# Or use individual components:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=outline
# DATABASE_USER=user
# DATABASE_PASSWORD=password

# Optional: database schema
# DATABASE_SCHEMA=

# Optional: connection pool URL (e.g. PgBouncer)
# DATABASE_CONNECTION_POOL_URL=

# Optional: connection pool size
# DATABASE_CONNECTION_POOL_MIN=
# DATABASE_CONNECTION_POOL_MAX=

# Optional: read replica for distributing read queries
# DATABASE_URL_READ_ONLY=

# SSL mode for PostgreSQL connection
# Options: disable, allow, require, prefer, verify-ca, verify-full
# PGSSLMODE=disable

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED - Redis
# ══════════════════════════════════════════════════════════════════════════════

REDIS_URL=redis://127.0.0.1:6379

# Optional: separate Redis instance for collaboration service
# REDIS_COLLABORATION_URL=

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED - Authentication (Microsoft Entra ID via Better Auth)
# ══════════════════════════════════════════════════════════════════════════════

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Microsoft Entra ID (Azure AD) OAuth credentials
# Register an app at https://portal.azure.com → App registrations
# Redirect URI: {URL}/api/better-auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Tenant ID for single-tenant apps, or "common" for multi-tenant
MICROSOFT_TENANT_ID=

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED - File Storage (Choose ONE option)
# ══════════════════════════════════════════════════════════════════════════════

# Options: "local" or "s3"
FILE_STORAGE=local

# --- Option A: Local storage ---
FILE_STORAGE_LOCAL_ROOT_DIR=./data

# --- Option B: S3-compatible storage ---
# FILE_STORAGE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_UPLOAD_BUCKET_NAME=
# AWS_S3_UPLOAD_BUCKET_URL=
# AWS_S3_FORCE_PATH_STYLE=true
# AWS_S3_ACL=private

# Optional: S3 accelerate endpoint
# AWS_S3_ACCELERATE_URL=

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Email (SMTP)
# ══════════════════════════════════════════════════════════════════════════════

# Either use SMTP_HOST or SMTP_SERVICE (not both)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_REPLY_EMAIL=
# SMTP_SECURE=true

# Or use a well-known service name (e.g. Gmail, SendGrid, Mailgun)
# SMTP_SERVICE=

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Application Settings
# ══════════════════════════════════════════════════════════════════════════════

# Auto-redirect HTTP to HTTPS (set to false behind a reverse proxy)
FORCE_HTTPS=false

# Default UI language
DEFAULT_LANGUAGE=en_US

# Which services to run (comma-separated)
# SERVICES=collaboration,websockets,worker,web

# Max file upload size in bytes (default: ~1MB)
# FILE_STORAGE_UPLOAD_MAX_SIZE=26214400

# Max import file size in bytes
# FILE_STORAGE_IMPORT_MAX_SIZE=26214400

# Allowed email domains for signup (comma-separated)
# ALLOWED_DOMAINS=example.com

# Number of worker processes (divide available memory by 512MB)
# WEB_CONCURRENCY=1

# Request timeout in milliseconds (default: 10000)
# REQUEST_TIMEOUT=10000

# Logging level: error, warn, info, http, verbose, debug, silly
# LOG_LEVEL=info

# Debug output (comma-separated namespaces)
# DEBUG=

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - SSL Termination (if not using a reverse proxy)
# ══════════════════════════════════════════════════════════════════════════════

# Base64 encoded SSL key and certificate
# SSL_KEY=
# SSL_CERT=

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Rate Limiting
# ══════════════════════════════════════════════════════════════════════════════

# RATE_LIMITER_ENABLED=false
# RATE_LIMITER_REQUESTS=1000
# RATE_LIMITER_DURATION_WINDOW=60
# RATE_LIMITER_COLLABORATION_REQUESTS=50

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Monitoring & Analytics
# ══════════════════════════════════════════════════════════════════════════════

# Sentry error tracking
# SENTRY_DSN=
# SENTRY_TUNNEL=

# Google Analytics (v3 or v4)
# GOOGLE_ANALYTICS_ID=

# DataDog metrics
# DD_API_KEY=
# DD_SERVICE=outline

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Collaboration Settings
# ══════════════════════════════════════════════════════════════════════════════

# WebSocket URL for collaboration (defaults to URL with ws:// protocol)
# COLLABORATION_URL=

# Max concurrent editors per document (default: 100)
# COLLABORATION_MAX_CLIENTS_PER_DOCUMENT=100

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Webhooks
# ══════════════════════════════════════════════════════════════════════════════

# Time window in seconds for failure analysis (default: 86400)
# WEBHOOK_FAILURE_TIME_WINDOW=86400

# Failure rate threshold to disable webhook (default: 80%)
# WEBHOOK_FAILURE_RATE_THRESHOLD=80

# ══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Network
# ══════════════════════════════════════════════════════════════════════════════

# Comma-separated IP/CIDR ranges allowed for private network access
# (useful for OIDC providers or webhooks on internal networks)
# ALLOWED_PRIVATE_IP_ADDRESSES=
